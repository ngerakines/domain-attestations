# Key material for HTTP signatures (required).
# Accepted formats: did:key:z... (multibase P-256 private key) OR a JWK JSON object.
# did:key example:  export HTTPSIG_PRIVATE_KEY="did:key:z..."
# JWK example:      export HTTPSIG_PRIVATE_KEY='{"kty":"EC","crv":"P-256","x":"...","y":"...","d":"..."}'
HTTPSIG_PRIVATE_KEY=

# Domain used to construct the did:web DID document (default: localhost:5000)
SERVER_DOMAIN=example.com

# Optional controller DID to include in the DID document's top-level "controller" field.
# SERVICE_CONTROLLER=did:plc:abc123

# Optional comma-separated list of alsoKnownAs values for the DID document.
# SERVICE_ALSO_KNOWN_AS=did:plc:abc123,at://handle.example.com
