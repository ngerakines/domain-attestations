# PEM-encoded ECDSA P-256 private key (required)
# Generate with: openssl ecparam -name prime256v1 -genkey -noout -out key.pem
# Then: export HTTPSIG_PRIVATE_KEY="$(cat key.pem)"
HTTPSIG_PRIVATE_KEY=

# Domain used to construct the did:web DID document (default: localhost:5000)
SERVER_DOMAIN=example.com
